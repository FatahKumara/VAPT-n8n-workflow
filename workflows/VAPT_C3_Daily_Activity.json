        }
      },
      "id": "m3000001-0000-0000-0000-000000000005",
      "name": "Send Not Registered Error",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1000,
        -350
      ],
      "credentials": {
        "telegramApi": {
