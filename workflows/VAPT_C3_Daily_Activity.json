    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const item = $input.first().json;\nconst data = item.data || {};\nconst hoursRaw = item.cbData ? item.cbData.replace('act:hours:', '') : item.text;\nconst hours = parseFloat(hoursRaw) || 0;\nconst today = new Date().toISOString().split('T')[0];\n\nreturn [{ json: {\n  chatId: item.chatId,\n  userId: item.userId,\n  data: { ...data, hours_spent: hours },\n  today,\n  notionPayload: {\n    log_id: `LOG-${Date.now()}`,\n    project_id: data.selectedProjectId,\n    pentester_id: data.pentesterNotionId,\n    log_date: today,\n    activity_description: data.activity_description || '',\n    findings_summary: data.findings_summary || '',\n    hours_spent: hours\n  }\n} }];"
      },
