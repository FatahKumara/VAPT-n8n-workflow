    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const pentester = $input.first().json;\nconst userId = $('Execute Workflow Trigger').first().json.userId;\nconst chatId = $('Execute Workflow Trigger').first().json.chatId;\nconst firstName = $('Execute Workflow Trigger').first().json.firstName;\n\nfunction getProp(props, key, type) {\n  const p = props?.[key];\n  if (!p) return null;\n  if (type === 'title') return p.title?.[0]?.plain_text || null;\n  if (type === 'text') return p.rich_text?.[0]?.plain_text || null;\n  if (type === 'relation') return (p.relation || []).map(r => r.id);\n  if (type === 'select') return p.select?.name || null;\n  return null;\n}\n\nconst pentesterNotionId = pentester.id;\nconst pentesterName = getProp(pentester.properties, 'name', 'text') || firstName;\nconst assignedProjectIds = getProp(pentester.properties, 'assigned_projects', 'relation') || [];\n\nreturn [{ json: { chatId, userId, pentesterNotionId, pentesterName, assignedProjectIds } }];"
      },
      "id": "m3000001-0000-0000-0000-000000000006",
      "name": "Extract Pentester Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        -200
      ]
    },
    {
      "parameters": {
        "resource": "databasePage",
        "operation": "getAll",
        "databaseId": "={{ $vars.NOTION_DB1_PROJECT_LIST }}",
        "returnAll": true,
        "options": {}
      },
      "id": "m3000001-0000-0000-0000-000000000007",
      "name": "Fetch Projects",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [
        1250,
        -200
      ],
      "credentials": {
        "notionApi": {
          "id": "{{ NOTION_CRED }}",
          "name": "Notion API"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const projects = $input.all().map(i => i.json);\nconst pentesterData = $('Extract Pentester Data').first().json;\nconst { chatId, pentesterNotionId, assignedProjectIds } = pentesterData;\n\nfunction getProp(props, key, type) {\n  const p = props?.[key];\n  if (!p) return '';\n  if (type === 'title') return p.title?.[0]?.plain_text || '';\n  if (type === 'text') return p.rich_text?.[0]?.plain_text || '';\n  if (type === 'select') return p.select?.name || '';\n  return '';\n}\n\nconst myProjects = projects.filter(p => {\n  const rels = p.properties?.assigned_pentesters?.relation || [];\n  return rels.some(r => r.id === pentesterNotionId) && getProp(p.properties, 'current_phase', 'select') !== 'Retest Report';\n});\n\nif (myProjects.length === 0) {\n  return [{ json: { chatId, noProjects: true } }];\n}\n\nconst buttons = myProjects.map(p => ({\n  text: `${getProp(p.properties, 'project_id', 'title')} — ${getProp(p.properties, 'current_phase', 'select')}`,\n  callback_data: `act:proj:${p.id}`\n}));\n\nreturn [{ json: {\n  chatId,\n  pentesterNotionId,\n  pentesterName: pentesterData.pentesterName,\n  inline_keyboard: buttons.map(b => [b])\n} }];"
      },
      "id": "m3000001-0000-0000-0000-000000000008",
      "name": "Filter Assigned Projects",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1500,
        -200
      ]
    },
    {
      "parameters": {
