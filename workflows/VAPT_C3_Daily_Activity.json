        "additionalFields": {
          "parse_mode": "HTML",
          "reply_markup": "{{ JSON.stringify({ inline_keyboard: [[{text:'4',callback_data:'act:hours:4'},{text:'5',callback_data:'act:hours:5'},{text:'6',callback_data:'act:hours:6'},{text:'7',callback_data:'act:hours:7'},{text:'8',callback_data:'act:hours:8'}]] }) }}"
        }
