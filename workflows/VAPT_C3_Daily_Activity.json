    {
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $('Execute Workflow Trigger').item.json.chatId }}",
        "text": "⛔ <b>Akses Ditolak</b>\n\nUser ID kamu tidak terdaftar sebagai pentester dalam sistem.\nHubungi Project Manager untuk pendaftaran.",
        "additionalFields": {
