      "id": "g7000001-0000-0000-0000-000000000003",
      "name": "Fetch Active Projects",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [
        500,
        -200
      ],
      "credentials": {
        "notionApi": {
          "id": "{{ NOTION_CRED }}",
          "name": "Notion API"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const projects = $input.all().map(i => i.json);\nconst chatId = $('Execute Workflow Trigger').first().json.chatId;\n\nfunction getProp(props, key, type) {\n  const p = props?.[key];\n  if (!p) return '';\n  if (type === 'title') return p.title?.[0]?.plain_text || '';\n  if (type === 'text') return p.rich_text?.[0]?.plain_text || '';\n  if (type === 'select') return p.select?.name || '';\n  return '';\n}\n\n// Filter out finished projects\nconst activeProjects = projects.filter(p => {\n  const status = getProp(p.properties, 'current_phase', 'select');\n  return status !== 'Retest Report'; // Show all including retest report\n});\n\nconst buttons = activeProjects.map(p => ({\n  text: `${getProp(p.properties, 'project_id', 'title')} | ${getProp(p.properties, 'current_phase', 'select')}`,\n  callback_data: `phase:proj:${p.id}`\n}));\n\nconst rows = [];\nfor (let i = 0; i < buttons.length; i += 1) {\n  rows.push([buttons[i]]);\n}\n\nreturn [{ json: { chatId, inline_keyboard: rows, count: activeProjects.length } }];"
      },
      "id": "g7000001-0000-0000-0000-000000000004",
      "name": "Build Project List",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        -200
      ]
    },
    {
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $json.chatId }}",
        "text": "🔄 <b>Update Fase Proyek</b>\n\nPilih proyek yang akan di-update:\n<i>Format: ID | Fase Saat Ini</i>",
        "additionalFields": {
          "parse_mode": "HTML",
          "reply_markup": "={{ JSON.stringify({ inline_keyboard: $json.inline_keyboard }) }}"
        }
      },
      "id": "g7000001-0000-0000-0000-000000000005",
      "name": "Send Project List",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1000,
        -200
      ],
      "credentials": {
        "telegramApi": {
          "id": "{{ TELEGRAM_BOT_A_CRED }}",
          "name": "Telegram Bot A - PM Assistant"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const incoming = $('Execute Workflow Trigger').first().json;\nconst cbData = incoming.callbackData || '';\nconst session = incoming.session || {};\nconst chatId = incoming.chatId;\n\nif (cbData.startsWith('phase:proj:')) {\n  const projectId = cbData.replace('phase:proj:', '');\n  return [{ json: { chatId, step: 'select_phase', projectId } }];\n}\nif (cbData.startsWith('phase:set:')) {\n  const parts = cbData.replace('phase:set:', '').split(':');\n  const projectId = parts[0];\n  const phase = parts.slice(1).join(':');\n  return [{ json: { chatId, step: 'set_phase', projectId, phase } }];\n}\nif (cbData.startsWith('status:set:')) {\n  const status = cbData.replace('status:set:', '');\n  const sessionData = session.data || {};\n  return [{ json: { chatId, step: 'set_status', projectId: sessionData.projectId, phase: sessionData.phase, status } }];\n}\nif (session.step === 'waiting_notes') {\n  const d = session.data || {};\n  return [{ json: { chatId, step: 'save_notes', projectId: d.projectId, phase: d.phase, status: d.status, notes: incoming.text } }];\n}\nreturn [{ json: { chatId, step: 'unknown' } }];"
      },
