                "conditions": [
                  {
                    "leftValue": "={{ $json.step }}",
                    "rightValue": "save_notes",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "save_and_update"
            }
          ]
        },
        "options": {}
      },
      "id": "g7000001-0000-0000-0000-000000000007",
      "name": "Route Callback Step",
