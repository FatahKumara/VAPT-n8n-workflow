    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const item = $input.first().json;\nconst today = new Date();\n\nconst phaseOrder = ['Pre-Kickoff','Kickoff','Initial Test','Initial Report','Presentation','Patching','Retest','Retest Report'];\nconst phaseDateMap = {\n  'Pre-Kickoff': 'date_pre_kickoff',\n  'Kickoff': 'date_kickoff',\n  'Initial Test': 'date_initial_test',\n  'Initial Report': 'date_initial_report',\n  'Presentation': 'date_presentation',\n  'Patching': 'date_patching',\n  'Retest': 'date_retest',\n  'Retest Report': 'date_retest_report'\n};\n\n// Status would be recalculated by Notion formula, but we set the phase\nconst notes = item.notes === '-' ? '' : (item.notes || '');\n\nreturn [{ json: {\n  chatId: item.chatId,\n  projectId: item.projectId,\n  phase: item.phase,\n  notes,\n  updateProperties: {\n    current_phase: { select: { name: item.phase } },\n    pm_notes: notes ? { rich_text: [{ text: { content: notes } }] } : undefined,\n    last_updated: { date: { start: today.toISOString().split('T')[0] } }\n  }\n} }];"
      },
