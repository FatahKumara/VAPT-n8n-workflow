    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const item = $input.first().json;\nconst today = new Date();\nconst notes = item.notes === '-' ? '' : (item.notes || '');\nconst projectStatus = item.status || '';\n\nreturn [{ json: {\n  chatId: item.chatId,\n  projectId: item.projectId,\n  phase: item.phase,\n  status: projectStatus,\n  notes,\n  updateProperties: {\n    current_phase: { select: { name: item.phase } },\n    project_status: projectStatus ? { select: { name: projectStatus } } : undefined,\n    pm_notes: notes ? { rich_text: [{ text: { content: notes } }] } : undefined,\n    last_updated: { date: { start: today.toISOString().split('T')[0] } }\n  }\n} }];"
      },
