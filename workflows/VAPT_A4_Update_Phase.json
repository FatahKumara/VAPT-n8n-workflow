        "chatId": "={{ $json.chatId }}",
        "text": "📍 Pilih fase baru untuk proyek ini:",
        "additionalFields": {
          "parse_mode": "HTML",
          "reply_markup": "={{ JSON.stringify({ inline_keyboard: [\n  [{text: '1️⃣ Pre-Kickoff', callback_data: 'phase:set:' + $json.projectId + ':Pre-Kickoff'}],\n  [{text: '2️⃣ Kickoff', callback_data: 'phase:set:' + $json.projectId + ':Kickoff'}],\n  [{text: '3️⃣ Initial Test', callback_data: 'phase:set:' + $json.projectId + ':Initial Test'}],\n  [{text: '4️⃣ Initial Report', callback_data: 'phase:set:' + $json.projectId + ':Initial Report'}],\n  [{text: '5️⃣ Presentation', callback_data: 'phase:set:' + $json.projectId + ':Presentation'}],\n  [{text: '6️⃣ Patching', callback_data: 'phase:set:' + $json.projectId + ':Patching'}],\n  [{text: '7️⃣ Retest', callback_data: 'phase:set:' + $json.projectId + ':Retest'}],\n  [{text: '8️⃣ Retest Report', callback_data: 'phase:set:' + $json.projectId + ':Retest Report'}]\n] }) }}"
        }
