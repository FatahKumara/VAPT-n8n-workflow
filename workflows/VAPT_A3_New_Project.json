    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Step handler factory\nconst item = $input.first().json;\nconst chatId = item.chatId;\nconst data = item.data || {};\nconst stepName = item.step;\nconst inputValue = item.text || item.cbData || '';\n\n// Determine what was just collected and what's next\nconst steps = [\n  { current: 'waiting_project_name',       field: 'project_id',       next: 'waiting_client_name',        stepNum: 2, question: 'Nama proyek lengkap:',              hint: 'Contoh: VAPT Infrastruktur PT ABC' },\n  { current: 'waiting_client_name',         field: 'client_name',      next: 'waiting_objects',             stepNum: 3, question: 'Daftar objek pengujian (pisahkan dengan koma):', hint: 'Contoh: Web App, API, Mobile App' },\n  { current: 'waiting_objects',             field: 'object_list',      next: 'waiting_methodology',         stepNum: 4, question: null, hint: null },\n  { current: 'waiting_methodology',         field: 'methodology',      next: 'waiting_date_pre_kickoff',    stepNum: 5, question: 'Tanggal Pre-Kickoff:', hint: 'Format: YYYY-MM-DD' },\n  { current: 'waiting_date_pre_kickoff',    field: 'date_pre_kickoff', next: 'waiting_date_kickoff',        stepNum: 6, question: 'Tanggal Kickoff:', hint: 'Format: YYYY-MM-DD' },\n  { current: 'waiting_date_kickoff',        field: 'date_kickoff',     next: 'waiting_date_initial_test',   stepNum: 7, question: 'Tanggal Mulai Initial Test:', hint: 'Format: YYYY-MM-DD' },\n  { current: 'waiting_date_initial_test',   field: 'date_initial_test',next: 'waiting_date_initial_report', stepNum: 8, question: 'Tanggal Initial Report:', hint: 'Format: YYYY-MM-DD' },\n  { current: 'waiting_date_initial_report', field: 'date_initial_report',next:'waiting_date_presentation',  stepNum: 9, question: 'Tanggal Presentasi:', hint: 'Format: YYYY-MM-DD' },\n  { current: 'waiting_date_presentation',   field: 'date_presentation',next: 'waiting_date_patching',       stepNum: 10, question: 'Tanggal Mulai Patching:', hint: 'Format: YYYY-MM-DD' },\n  { current: 'waiting_date_patching',       field: 'date_patching',    next: 'waiting_date_retest',          stepNum: 11, question: 'Tanggal Retest:', hint: 'Format: YYYY-MM-DD' },\n  { current: 'waiting_date_retest',         field: 'date_retest',      next: 'waiting_date_retest_report',   stepNum: 12, question: 'Tanggal Retest Report:', hint: 'Format: YYYY-MM-DD' },\n  { current: 'waiting_date_retest_report',  field: 'date_retest_report',next: 'COMPLETE',                   stepNum: null, question: null, hint: null }\n];\n\nconst currentStepDef = steps.find(s => s.current === stepName);\nif (!currentStepDef) return [{ json: { error: 'Unknown step: ' + stepName, chatId } }];\n\nconst updatedData = { ...data, [currentStepDef.field]: inputValue };\nconst nextStep = currentStepDef.next;\n\nreturn [{ json: { chatId, data: updatedData, nextStep, nextQuestion: currentStepDef.question ? { step: currentStepDef.stepNum, question: currentStepDef.question, hint: currentStepDef.hint } : null } }];"
      },
