    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const data = $('Build Notion Payload').first().json.data;\nconst projectId = $('Build Notion Payload').first().json.projectId;\nconst chatId = $('Build Notion Payload').first().json.chatId;\n\nconst confirmText = [\n  '✅ <b>Proyek Berhasil Dibuat!</b>',\n  '',\n  `📋 <b>ID Proyek:</b> ${projectId}`,\n  `🏷 <b>Nama:</b> ${data.project_name}`,\n  `🏢 <b>Klien:</b> ${data.client_name}`,\n  `🎯 <b>Metodologi:</b> ${(data.methodology || '').replace('np:method:', '')}`,\n  `📦 <b>Objek:</b> ${data.object_list}`,\n  '',\n  '<b>📅 Timeline:</b>',\n  `• Pre-Kickoff: ${data.date_pre_kickoff}`,\n  `• Kickoff: ${data.date_kickoff}`,\n  `• Initial Test: ${data.date_initial_test}`,\n  `• Initial Report: ${data.date_initial_report}`,\n  `• Presentasi: ${data.date_presentation}`,\n  `• Patching: ${data.date_patching}`,\n  `• Retest: ${data.date_retest}`,\n  `• Retest Report: ${data.date_retest_report}`,\n  '',\n  '📍 <b>Status:</b> Pre-Engagement | Fase: Pre-Kickoff',\n  '',\n  '📊 Data tersimpan di Notion. Gunakan /update_phase untuk update fase proyek.'\n].join('\\n');\n\nreturn [{ json: { chatId, text: confirmText } }];"
      },
