        "jsCode": "const incoming = $('Execute Workflow Trigger').first().json;\nconst session = incoming.session || {};\nconst step = session.step;\nconst data = session.data || {};\nconst chatId = incoming.chatId;\nconst text = incoming.text || '';\nconst cbData = incoming.callbackData || '';\n\nreturn [{ json: { chatId, step, data, text, cbData } }];"
