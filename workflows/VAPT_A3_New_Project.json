          "reply_markup": "{\"inline_keyboard\": [[{\"text\": \"⬛ Black Box\", \"callback_data\": \"np:method:Black Box\"}, {\"text\": \"🔲 Grey Box\", \"callback_data\": \"np:method:Grey Box\"}, {\"text\": \"⬜ White Box\", \"callback_data\": \"np:method:White Box\"}]]}"
