    {
      "parameters": {
        "resource": "databasePage",
        "operation": "getAll",
        "databaseId": "={{ $vars.NOTION_DB2_PENTESTER_LIST }}",
        "returnAll": true,
        "options": {}
      },
      "id": "f6000001-0000-0000-0000-000000000014",
      "name": "Fetch Active Pentesters",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [
        1500,
        300
      ],
      "credentials": {
        "notionApi": {
          "id": "{{ NOTION_CRED }}",
          "name": "Notion API"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const pentesters = $input.all().map(i => i.json);\nconst prevData = $('Is Complete?').first().json;\n\nfunction getProp(props, key, type) {\n  const p = props?.[key];\n  if (!p) return '';\n  if (type === 'title') return p.title?.[0]?.plain_text || '';\n  if (type === 'text') return p.rich_text?.[0]?.plain_text || '';\n  if (type === 'select') return p.select?.name || '';\n  return '';\n}\n\nconst data = prevData.data || {};\n\n// Build Notion DB-1 create payload\nconst projectId = data.project_id || `VAPT-${new Date().getFullYear()}-${Math.floor(Math.random()*999).toString().padStart(3,'0')}`;\n\n// Parse objects into multi-select format\nconst objects = (data.object_list || '').split(',').map(o => ({ name: o.trim() })).filter(o => o.name);\n\nconst notionPayload = {\n  parent: { database_id: prevData.dbId },\n  properties: {\n    project_id: { title: [{ text: { content: projectId } }] },\n    project_name: { rich_text: [{ text: { content: data.project_name || '' } }] },\n    client_name: { rich_text: [{ text: { content: data.client_name || '' } }] },\n    object_list: { multi_select: objects },\n    methodology: { select: { name: (data.methodology || '').replace('np:method:', '') } },\n    current_phase: { select: { name: 'Pre-Kickoff' } },\n    date_pre_kickoff: data.date_pre_kickoff ? { date: { start: data.date_pre_kickoff } } : undefined,\n    date_kickoff: data.date_kickoff ? { date: { start: data.date_kickoff } } : undefined,\n    date_initial_test: data.date_initial_test ? { date: { start: data.date_initial_test } } : undefined,\n    date_initial_report: data.date_initial_report ? { date: { start: data.date_initial_report } } : undefined,\n    date_presentation: data.date_presentation ? { date: { start: data.date_presentation } } : undefined,\n    date_patching: data.date_patching ? { date: { start: data.date_patching } } : undefined,\n    date_retest: data.date_retest ? { date: { start: data.date_retest } } : undefined,\n    date_retest_report: data.date_retest_report ? { date: { start: data.date_retest_report } } : undefined,\n    project_status: { select: { name: 'Not Started' } }\n  }\n};\n\n// Remove undefined values\nObject.keys(notionPayload.properties).forEach(k => {\n  if (notionPayload.properties[k] === undefined) delete notionPayload.properties[k];\n});\n\nreturn [{ json: { chatId: prevData.chatId, data, projectId, notionPayload } }];"
      },
      "id": "f6000001-0000-0000-0000-000000000015",
      "name": "Build Notion Payload",
      "type": "n8n-nodes-base.code",
