      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const incoming = $('Parse Incoming Message').first().json;\nconst sessionRaw = $input.first().json.value || null;\nlet session = null;\ntry { session = sessionRaw ? JSON.parse(sessionRaw) : null; } catch(e) { session = null; }\n\nconst command = incoming.command;\nconst callbackData = incoming.callbackData;\nconst sessionStep = session?.step || null;\nconst sessionCommand = session?.command || null;\n\n// Determine routing key\nlet route;\nif (callbackData) {\n  if (callbackData.startsWith('sow:') || callbackData.startsWith('roe:')) route = 'a1_callback';\n  else if (callbackData.startsWith('proposal:')) route = 'a2_callback';\n  else if (callbackData.startsWith('np:')) route = 'a3_session';\n  else if (callbackData.startsWith('phase:') || callbackData.startsWith('proj:') || callbackData.startsWith('status:')) route = 'a4_callback';\n  else route = 'unknown_callback';\n} else if (command === '/generate_sow' || command === '/generate_roe') {\n  route = 'a1';\n} else if (command === '/generate_proposal') {\n  route = 'a2';\n} else if (command === '/new_project') {\n  route = 'a3_init';\n} else if (command === '/update_phase') {\n  route = 'a4';\n} else if (command === '/summary') {\n  route = 'a5';\n} else if (command === '/help' || command === '/start') {\n  route = 'help';\n} else if (sessionStep && sessionCommand === '/new_project') {\n  route = 'a3_session';\n} else {\n  route = 'unknown';\n}\n\nreturn [{ json: { ...incoming, session, route } }];"
      },
