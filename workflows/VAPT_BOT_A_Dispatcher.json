    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst message = body.message || body.edited_message;\nconst cbq = body.callback_query;\n\nlet chatId, userId, text, callbackData, firstName;\n\nif (cbq) {\n  chatId = cbq.message.chat.id;\n  userId = cbq.from.id;\n  text = null;\n  callbackData = cbq.data;\n  firstName = cbq.from.first_name || 'PM';\n} else if (message) {\n  chatId = message.chat.id;\n  userId = message.from.id;\n  text = message.text || '';\n  callbackData = null;\n  firstName = message.from.first_name || 'PM';\n} else {\n  return [];\n}\n\nconst command = text && text.startsWith('/') ? text.split(' ')[0].split('@')[0].toLowerCase() : null;\n\nreturn [{ json: { chatId, userId: String(userId), text, callbackData, firstName, command } }];"
      },
      "id": "c3000001-0000-0000-0000-000000000002",
      "name": "Parse Incoming Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        250,
