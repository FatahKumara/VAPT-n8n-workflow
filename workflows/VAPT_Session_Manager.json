        "jsCode": "const items = $input.all();\nconst trigger = $('Execute Workflow Trigger').first().json;\nconst exists = items && items.length > 0 && items[0].json.id;\nconst pageId = exists ? items[0].json.id : null;\nreturn [{ json: {\n  session_key: trigger.session_key,\n  session_data: trigger.session_data || '',\n  pageId,\n  exists: !!exists\n} }];"
      },
