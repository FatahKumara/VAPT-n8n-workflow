    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst trigger = $('Execute Workflow Trigger').first().json;\nif (!items || items.length === 0 || !items[0].json.id) {\n  return [{ json: { value: null } }];\n}\nconst page = items[0].json;\nconst props = page.properties || {};\nconst sessionDataProp = props.session_data;\nlet value = null;\nif (sessionDataProp) {\n  if (sessionDataProp.rich_text) {\n    value = sessionDataProp.rich_text.map(t => t.plain_text || '').join('');\n  }\n}\nif (value === '') value = null;\nreturn [{ json: { value } }];"
      },
      "id": "sm000001-0000-0000-0000-000000000004",
      "name": "GET - Extract Value",
      "type": "n8n-nodes-base.code",
