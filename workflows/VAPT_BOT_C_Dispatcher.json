    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst message = body.message;\nconst cbq = body.callback_query;\n\nlet chatId, userId, text, callbackData, firstName, chatType;\n\nif (cbq) {\n  chatId = String(cbq.message.chat.id);\n  userId = String(cbq.from.id);\n  text = null;\n  callbackData = cbq.data;\n  firstName = cbq.from.first_name || '';\n  chatType = cbq.message.chat.type;\n} else if (message) {\n  chatId = String(message.chat.id);\n  userId = String(message.from.id);\n  text = message.text || '';\n  callbackData = null;\n  firstName = message.from.first_name || '';\n  chatType = message.chat.type;\n} else {\n  return [];\n}\n\nconst command = text && text.startsWith('/') ? text.split(' ')[0].split('@')[0].toLowerCase() : null;\nconst allowedChatId = String($vars.PENTESTER_GROUP_CHAT_ID);\nconst isAllowedGroup = chatId === allowedChatId;\n\nreturn [{ json: { chatId, userId, text, callbackData, firstName, chatType, command, isAllowedGroup } }];"
      },
