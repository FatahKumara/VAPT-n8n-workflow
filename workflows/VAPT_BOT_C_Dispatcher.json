      "id": "l2000001-0000-0000-0000-000000000004",
      "name": "Get User Session",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [
        750,
        -150
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const incoming = $('Parse Message').first().json;\nconst sessionRaw = $input.first().json.value || null;\nlet session = null;\ntry { session = sessionRaw ? JSON.parse(sessionRaw) : null; } catch(e) {}\n\nconst command = incoming.command;\nconst callbackData = incoming.callbackData;\nconst sessionStep = session?.step;\nconst sessionCommand = session?.command;\n\nlet route;\nif (callbackData) {\n  if (callbackData.startsWith('act:')) route = 'c3_session';\n  else if (callbackData.startsWith('vuln:')) route = 'c4_session';\n  else route = 'unknown_callback';\n} else if (command === '/summary') {\n  route = 'c1_summary';\n} else if (command === '/update_activity') {\n  route = 'c3_init';\n} else if (command === '/add_vuln') {\n  route = 'c4_init';\n} else if (command === '/help' || command === '/start') {\n  route = 'help';\n} else if (sessionStep && sessionCommand === '/update_activity') {\n  route = 'c3_session';\n} else if (sessionStep && sessionCommand === '/add_vuln') {\n  route = 'c4_session';\n} else {\n  route = 'unknown';\n}\n\nreturn [{ json: { ...incoming, session, route } }];"
      },
