    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const item = $input.first().json;\nconst data = item.data || {};\nconst templateText = item.templateText || '';\nconst fullData = { ...data, estimated_scope: item.text };\n\nconst templateSection = templateText\n  ? '\\n\\n---\\nTEMPLATE ACUAN PROPOSAL\\nIkuti struktur, format, dan gaya penulisan template berikut secara konsisten:\\n\\n' + templateText + '\\n---'\n  : '';\n\nconst systemPrompt = 'Kamu adalah konsultan keamanan siber senior dan penulis proposal profesional. Buat proposal layanan VAPT (Vulnerability Assessment and Penetration Testing) yang komprehensif dalam Bahasa Indonesia.' + templateSection + '\\n\\nJika template acuan tersedia, ikuti struktur dan formatnya secara konsisten. Proposal harus mencakup:\\n1. Executive Summary\\n2. Latar Belakang & Kebutuhan\\n3. Ruang Lingkup Pengujian\\n4. Metodologi Pengujian: ' + (fullData.methodology || '') + '\\n5. Timeline Pelaksanaan\\n6. Deliverables\\n7. Tim Pelaksana\\n8. Investasi (placeholder [HARGA])\\n9. Ketentuan & Syarat\\n10. Tentang Perusahaan\\n\\nGunakan bahasa profesional dan persuasif.';\n\nreturn [{ json: { chatId: item.chatId, data: fullData, systemPrompt, userMessage: JSON.stringify(fullData, null, 2) } }];"
      },
