      "id": "e5000001-0000-0000-0000-000000000016",
      "name": "Generate Proposal via Claude",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [
        1500,
        450
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const generated = $input.first().json.text || '';\nconst chatId = $('Build Proposal Prompt').first().json.chatId;\nconst clientName = $('Build Proposal Prompt').first().json.data.client_name;\n\n// Clear session\nconst clearKey = `vapt:session:${chatId}`;\n\nconst MAX_LEN = 4000;\nconst header = `💼 <b>PROPOSAL VAPT — ${clientName}</b>\\n${'═'.repeat(30)}\\n\\n`;\nconst fullText = header + generated;\n\nconst messages = [];\nif (fullText.length <= MAX_LEN) {\n  messages.push({ chatId, text: fullText, clearKey });\n} else {\n  let remaining = fullText;\n  let first = true;\n  while (remaining.length > 0) {\n    let chunk = remaining.substring(0, MAX_LEN);\n    const lb = chunk.lastIndexOf('\\n\\n');\n    if (lb > MAX_LEN * 0.5) chunk = remaining.substring(0, lb + 2);\n    messages.push({ chatId, text: chunk, clearKey: first ? clearKey : null });\n    remaining = remaining.substring(chunk.length);\n    first = false;\n  }\n}\n\nreturn messages.map(m => ({ json: m }));"
      },
